{
  "name": "logic-garden",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "pnpm run icons:check && pnpm run templates:check",
    "build": "tsc -b && vite build && pnpm run build:budget",
    "build:budget": "node scripts/check-build-budget.mjs",
    "release:metrics": "node scripts/check-build-budget.mjs --json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --maxWorkers=1 --exclude src/tests/contentCorpus.test.ts",
    "test:e2e": "playwright test",
    "spellcheck": "cspell lint --no-progress",
    "icons:build": "node scripts/generate-fluent-icons.mjs",
    "icons:check": "node scripts/generate-fluent-icons.mjs --check",
    "templates:build": "tsx scripts/generate-puzzle-templates.ts",
    "templates:repair": "tsx scripts/generate-puzzle-templates.ts --repair",
    "templates:check": "tsx scripts/generate-puzzle-templates.ts --check",
    "terrain:samples": "tsx scripts/generate-terrain-samples.ts",
    "pwa:check": "node scripts/check-pwa.mjs",
    "preview": "vite preview",
    "verify": "pnpm run format:check && pnpm run spellcheck && pnpm run lint && pnpm run icons:check && pnpm run templates:check && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run pwa:check"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "fflate": "0.8.3",
    "idb-keyval": "^6.3.0",
    "lucide-react": "^1.24.0",
    "pixi.js": "^8.19.0",
    "qrcode-generator": "^2.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@cspell/dict-ca": "^3.1.2",
    "@cspell/dict-es-es": "^3.0.8",
    "@eslint/js": "^10.0.1",
    "@iconify-json/fluent-emoji-flat": "^1.2.5",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "cspell": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fast-check": "^4.9.0",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.5",
    "sharp": "0.34.5",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
